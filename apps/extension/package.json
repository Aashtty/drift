{
  "name": "@drift/extension",
  "displayName": "DRIFT — Doom Scroll Detector",
  "version": "0.1.0",
  "description": "Notices when you've drifted into a scroll hole and nudges you back to DRIFT.",
  "author": "you",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "plasmo": "0.90.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.280",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3"
  },
  "manifest": {
    "permissions": [
      "storage",
      "tabs"
    ],
    "host_permissions": [
      "https://*/*"
    ]
  }
}